{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/l/:slug",
      "destination": "/api/shortlink-redirect?slug=:slug"
    },
    {
      "source": "/s/blog/:slug",
      "destination": "/api/blog-share?slug=:slug"
    },
    {
      "source": "/og/blog/:slug.jpg",
      "destination": "/api/blog-og-image?slug=:slug"
    },
    {
      "source": "/((?!robots\\.txt|assets/).*)",
      "destination": "/index.html"
    }
  ]
}
